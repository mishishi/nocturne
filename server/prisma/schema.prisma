generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  openid      String    @unique
  firstSeen   DateTime  @default(now())
  totalDreams Int       @default(0)
  isMember    Boolean   @default(false)
  memberSince DateTime?
  sessions    Session[]
}

model Session {
  id                   String    @id @default(cuid())
  openid               String
  status               String    @default("PENDING") // PENDING, Q1-Q5, COLLECTING, COMPLETED
  dreamFragment        String    @default("")
  questions            String[]  @default([])
  currentQuestionIndex Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?
  user                 User      @relation(fields: [openid], references: [openid])
  messages             Message[]
  answers              Answer[]
  story                Story?
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // user | assistant
  content   String
  msgType   String   @default("text") // text | voice
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Answer {
  id            String   @id @default(cuid())
  sessionId     String
  questionIndex Int
  questionText  String
  answerText   String   @default("")
  answeredAt    DateTime @default(now())
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Story {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  title           String
  content         String
  wordCount       Int?
  promptTokens    Int?
  completionTokens Int?
  createdAt       DateTime @default(now())
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
